{
  "name": "@vollcrypt/node",
  "version": "0.1.6",
  "description": "Cross-platform, quantum-resistant cryptography engine for Node.js - native binding",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "npx @napi-rs/cli build --platform --release"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeratVural/vollcrypt.git",
    "directory": "node"
  },
  "homepage": "https://github.com/BeratVural/vollcrypt#readme",
  "bugs": {
    "url": "https://github.com/BeratVural/vollcrypt/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.d.ts",
    "index.js",
    "vollcrypt.*.node"
  ],
  "keywords": [
    "vollcrypt",
    "cryptography",
    "encryption",
    "aes-gcm",
    "ed25519",
    "x25519",
    "ml-kem",
    "post-quantum",
    "pqc",
    "e2ee",
    "napi"
  ],
  "author": "Berat Vural <berat.vural.tr@gmail.com>",
  "license": "GPL-3.0-only",
  "napi": {
    "name": "vollcrypt",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl"
      ]
    }
  }
}
