{
  "name": "@vollcrypt/messages-wasm",
  "version": "0.9.1",
  "description": "Cross-platform, quantum-resistant cryptography engine - WebAssembly binding",
  "type": "module",
  "main": "pkg/wasm.js",
  "types": "pkg/wasm.d.ts",
  "exports": {
    ".": {
      "types": "./pkg/wasm.d.ts",
      "import": "./pkg/wasm.js"
    },
    "./fast": {
      "types": "./fast.d.ts",
      "import": "./fast.js"
    }
  },
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg",
    "postbuild": "node -e \"const fs = require('fs'); try { fs.unlinkSync('pkg/.gitignore'); } catch (e) {}\""
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeratVural/vollcrypt.git",
    "directory": "wasm"
  },
  "homepage": "https://github.com/BeratVural/vollcrypt#readme",
  "bugs": {
    "url": "https://github.com/BeratVural/vollcrypt/issues"
  },
  "files": [
    "pkg/wasm.js",
    "pkg/wasm.d.ts",
    "pkg/wasm_bg.wasm",
    "pkg/wasm_bg.wasm.d.ts",
    "fast.js",
    "fast.d.ts",
    "README.md",
    "LICENSE",
    "LICENSE-COMMERCIAL.md",
    "LICENSE-GPL",
    "CHANGELOG.md"
  ],
  "keywords": [
    "vollcrypt",
    "cryptography",
    "encryption",
    "wasm",
    "webassembly",
    "aes-gcm",
    "ed25519",
    "x25519",
    "ml-kem",
    "post-quantum",
    "pqc",
    "e2ee"
  ],
  "author": "Berat Vural <berat.vural.tr@gmail.com>",
  "license": "GPL-3.0-only OR LicenseRef-Commercial"
}
