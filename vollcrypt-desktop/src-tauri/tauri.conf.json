{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VOLLcrypt",
  "version": "0.3.0",
  "identifier": "com.vollcrypt.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vollcrypt",
        "width": 800,
        "height": 780,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["voll"],
        "name": "VOLLcrypt Encrypted Container",
        "description": "VOLLcrypt secure encrypted file or folder container",
        "mimeType": "application/vnd.vollcrypt.file",
        "role": "Editor"
      }
    ],
    "licenseFile": "../License.rtf",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": {
        "bannerPath": "../installer-assets/wix-banner.png",
        "dialogImagePath": "../installer-assets/wix-dialog.png"
      },
      "nsis": {
        "sidebarImage": "../installer-assets/nsis-sidebar.bmp",
        "headerImage": "../installer-assets/nsis-header.bmp"
      }
    }
  }
}
